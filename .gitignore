# Hugo 构建产物
public/
resources/
.hugo_build.lock

# Python 缓存
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/

# 环境变量与密钥（绝对不能提交）
.env
.env.local
*.key
*.pem

# 本地数据库（位于data/外，避免Hugo解析.db）
db/
data/*.db
data/*.db-journal

# 数据采集快照（位于data/外，避免Hugo解析.jsonl；可选提交历史快照）
snapshots/

# Mock 与日志
mock_server/logs/
*.log

# node_modules（如果未来引入前端工具链）
node_modules/

# IDE
.idea/
.vscode/
.DS_Store

# 临时报告
reports/*.tmp

# ========== 补充：macOS resource forks / Hugo 构建产物 / 多语言输出 ==========

# macOS resource forks（包括 ._resources, ._.hugo_build.lock 等）
._*
**/._*

# Hugo 构建产物
hugo_stats.json
_hugo_stats.json

# 多语言构建输出目录
public-*/

# macOS 资源 fork 副本（显式）
._resources

# 环境变量示例文件
.env.local.example
